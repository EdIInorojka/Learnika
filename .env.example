# Learnika local development only.
# These values are placeholders for Docker Compose on a developer machine.
# Do not use these credentials in production, staging, shared environments or real user data.

COMPOSE_PROJECT_NAME=learnika

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=learnika_local
POSTGRES_USER=learnika_local
POSTGRES_PASSWORD=learnika_local_password
DATABASE_URL=postgresql://learnika_local:learnika_local_password@127.0.0.1:5432/learnika_local

AUTH_TOKEN_SECRET=learnika_local_auth_token_secret_replace_before_any_shared_environment_64_chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=learnika_local_redis_password
REDIS_URL=redis://:learnika_local_redis_password@127.0.0.1:6379/0

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=learnika_local_minio
MINIO_ROOT_PASSWORD=learnika_local_minio_password
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=learnika-local
S3_ACCESS_KEY_ID=learnika_local_minio
S3_SECRET_ACCESS_KEY=learnika_local_minio_password
S3_FORCE_PATH_STYLE=true
