{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "validate": {
      "dependsOn": ["format:check", "lint", "typecheck", "test"],
      "cache": false
    }
  }
}
