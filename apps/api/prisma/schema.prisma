generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PARENT
  CHILD
  MENTOR
  TEACHER
  ADMIN
}

enum FamilyMemberRole {
  OWNER
  CAREGIVER
  CHILD
  MENTOR
}

enum ConsentSubjectType {
  FAMILY
  CHILD
}

enum AuditActorType {
  USER
  SYSTEM
}

enum AuditOutcome {
  SUCCESS
  DENIED
  ERROR
}

enum HomeworkSessionStatus {
  CREATED
  WAITING_FOR_ATTEMPT
  PAUSED
  CANCELLED
  CLOSED
}

enum HomeworkSourceType {
  MANUAL
  IMAGE
  SCREENSHOT
  PDF
  UNKNOWN
}

enum HomeworkAttemptStatus {
  CREATED
  SUBMITTED
  CANCELLED
}

enum MediaAssetKind {
  HOMEWORK_IMAGE
  HOMEWORK_SCREENSHOT
  HOMEWORK_PDF
  VOICE_AUDIO
  OTHER
}

enum MediaRetentionStatus {
  TEMPORARY
  RETENTION_EXPIRED
  DELETION_REQUESTED
  DELETED
}

model User {
  id                       String             @id @default(uuid()) @db.Uuid
  accountRole              UserRole
  email                    String?            @unique @db.VarChar(320)
  passwordHash             String?            @db.VarChar(255)
  locale                   String             @default("ru") @db.VarChar(16)
  disabledAt               DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  auditLogs                AuditLog[]         @relation("AuditActor")
  authSessions             AuthSession[]
  childProfile             ChildProfile?
  consentRecordsGranted    ConsentRecord[]    @relation("ConsentGrantedBy")
  createdHomeworkAttempts  HomeworkAttempt[]  @relation("HomeworkAttemptCreatedBy")
  createdHomeworkSessions  HomeworkSession[]  @relation("HomeworkSessionCreatedBy")
  createdMediaAssets       MediaAsset[]       @relation("MediaAssetCreatedBy")
  familyMemberships        FamilyMember[]
}

model AuthSession {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid
  accessTokenHash       String    @unique @db.VarChar(128)
  refreshTokenHash      String    @unique @db.VarChar(128)
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())
  lastUsedAt            DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accessTokenHash])
  @@index([refreshTokenHash])
  @@index([revokedAt, refreshTokenExpiresAt])
  @@index([userId])
}

model Family {
  id                 String              @id @default(uuid()) @db.Uuid
  displayName        String?             @db.VarChar(120)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  auditLogs          AuditLog[]
  childProfiles      ChildProfile[]
  consentRecords     ConsentRecord[]
  homeworkAttempts   HomeworkAttempt[]
  homeworkSessions   HomeworkSession[]
  mediaAssets        MediaAsset[]
  members            FamilyMember[]
  textbookSelections TextbookSelection[]
}

model FamilyMember {
  id        String           @id @default(uuid()) @db.Uuid
  familyId  String           @db.Uuid
  userId    String           @db.Uuid
  role      FamilyMemberRole
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([familyId, userId])
  @@index([familyId, role])
  @@index([userId])
}

model ChildProfile {
  id                 String              @id @default(uuid()) @db.Uuid
  familyId           String              @db.Uuid
  userId             String?             @unique @db.Uuid
  nickname           String?             @db.VarChar(120)
  gradeLevel         Int?
  locale             String              @default("ru") @db.VarChar(16)
  archivedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  consentRecords     ConsentRecord[]
  family             Family              @relation(fields: [familyId], references: [id], onDelete: Cascade)
  homeworkAttempts   HomeworkAttempt[]
  homeworkSessions   HomeworkSession[]
  mediaAssets        MediaAsset[]
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  textbookSelections TextbookSelection[]

  @@index([familyId])
  @@index([familyId, gradeLevel])
}

model ConsentRecord {
  id              String             @id @default(uuid()) @db.Uuid
  familyId        String             @db.Uuid
  childProfileId  String?            @db.Uuid
  subjectType     ConsentSubjectType
  purpose         String             @db.VarChar(80)
  documentVersion String             @db.VarChar(80)
  policyVersion   String             @db.VarChar(80)
  grantedByUserId String             @db.Uuid
  grantedAt       DateTime           @default(now())
  revokedAt       DateTime?
  createdAt       DateTime           @default(now())
  childProfile    ChildProfile?      @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  family          Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  grantedBy       User               @relation("ConsentGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  @@index([familyId, childProfileId])
  @@index([familyId, purpose, documentVersion])
  @@index([grantedByUserId])
}

model TextbookSelection {
  id             String       @id @default(uuid()) @db.Uuid
  familyId       String       @db.Uuid
  childProfileId String       @db.Uuid
  subject        String       @default("math") @db.VarChar(40)
  gradeLevel     Int?
  textbookCode   String       @db.VarChar(120)
  selectedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  family         Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, childProfileId])
  @@index([familyId, subject, gradeLevel])
}

model HomeworkSession {
  id             String                @id @default(uuid()) @db.Uuid
  familyId       String                @db.Uuid
  childProfileId String                @db.Uuid
  createdByUserId String?              @db.Uuid
  subject        String                @default("math") @db.VarChar(40)
  gradeLevel     Int?
  sourceType     HomeworkSourceType    @default(UNKNOWN)
  status         HomeworkSessionStatus @default(CREATED)
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  attempts       HomeworkAttempt[]
  childProfile   ChildProfile          @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  createdBy      User?                 @relation("HomeworkSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  family         Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  mediaAssets    MediaAsset[]

  @@index([familyId, childProfileId])
  @@index([familyId, status])
  @@index([createdByUserId])
}

model HomeworkAttempt {
  id                String                @id @default(uuid()) @db.Uuid
  familyId          String                @db.Uuid
  homeworkSessionId String                @db.Uuid
  childProfileId    String                @db.Uuid
  createdByUserId   String?               @db.Uuid
  attemptNumber     Int
  status            HomeworkAttemptStatus @default(CREATED)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  childProfile      ChildProfile          @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  createdBy         User?                 @relation("HomeworkAttemptCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  family            Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  homeworkSession   HomeworkSession       @relation(fields: [homeworkSessionId], references: [id], onDelete: Cascade)

  @@unique([homeworkSessionId, attemptNumber])
  @@index([familyId, childProfileId])
  @@index([familyId, status])
  @@index([createdByUserId])
}

model MediaAsset {
  id                   String               @id @default(uuid()) @db.Uuid
  familyId             String               @db.Uuid
  childProfileId       String?              @db.Uuid
  homeworkSessionId    String?              @db.Uuid
  createdByUserId      String?              @db.Uuid
  assetKind            MediaAssetKind
  storageKey           String?              @db.VarChar(512)
  mimeType             String               @db.VarChar(120)
  sizeBytes            BigInt
  checksumSha256       String?              @db.VarChar(64)
  retentionStatus      MediaRetentionStatus @default(TEMPORARY)
  retentionUntil       DateTime
  deletionRequestedAt  DateTime?
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  childProfile         ChildProfile?        @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  createdBy            User?                @relation("MediaAssetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  family               Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  homeworkSession      HomeworkSession?     @relation(fields: [homeworkSessionId], references: [id], onDelete: SetNull)

  @@index([familyId, childProfileId])
  @@index([familyId, retentionStatus, retentionUntil])
  @@index([homeworkSessionId])
  @@index([createdByUserId])
}

model AuditLog {
  id            String         @id @default(uuid()) @db.Uuid
  familyId      String?        @db.Uuid
  actorUserId   String?        @db.Uuid
  actorType     AuditActorType
  action        String         @db.VarChar(120)
  targetType    String?        @db.VarChar(120)
  targetId      String?        @db.VarChar(120)
  outcome       AuditOutcome
  policyVersion String?        @db.VarChar(80)
  createdAt     DateTime       @default(now())
  actor         User?          @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  family        Family?        @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([familyId, createdAt])
}
