{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "target": "ES2022",
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
